{
  "name": "skill-bridge-career-navigator",
  "version": "1.0.0",
  "description": "Skill-Bridge Career Navigator - PAN Case Study",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "test": "jest tests/ --forceExit",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "start:server": "cd server && npm start",
    "install:all": "cd server && npm install && cd ../client && npm install",
    "build:embeddings": "cd server && npm run build:embeddings",
    "evaluate:retrieval": "node server/scripts/evaluateRetrieval.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 35000,
    "moduleNameMapper": {
      "^better-sqlite3$": "<rootDir>/server/node_modules/better-sqlite3"
    }
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "groq-sdk": "^0.3.3"
  }
}
